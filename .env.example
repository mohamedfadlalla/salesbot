# Telegram Configuration
# Mode: "bot" (default, uses @BotFather token) or "user" (uses real user account via Pyrogram)
TELEGRAM_MODE=bot

# Bot mode token (from @BotFather) — required when TELEGRAM_MODE=bot
BOT_TOKEN=your_telegram_bot_token_here

# User mode credentials (from https://my.telegram.org) — required when TELEGRAM_MODE=user
API_ID=your_api_id_here
API_HASH=your_api_hash_here
SESSION_NAME=userbot_session

# AI Provider Configuration
# Supported: ollama, openrouter, gemini
AI_PROVIDER=ollama

# Ollama Cloud (default)
OLLAMA_HOST=https://ollama.com
OLLAMA_API_KEY=your_ollama_api_key_here
OLLAMA_MODEL=gemma3:27b

# OpenRouter (optional - uncomment to use)
# OPENROUTER_API_KEY=your_openrouter_api_key_here
# OPENROUTER_MODEL=google/gemini-2.0-flash-001

# Gemini (optional - uncomment to use)
# GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-2.0-flash

# Bot Settings
DEBOUNCE_SECONDS=3.0
MAX_HISTORY_MESSAGES=20
DATABASE_PATH=data/bot.db
LOG_LEVEL=INFO
LOG_FILE=logs/bot.log